{
    "name": "nullaidev/vista",
    "description": "Vista view render engine.",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^2"
    },
    "autoload": {
        "psr-4": {"Nullai\\Vista\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {"Tests\\": "tests/"}
    },
    "bin": ["bin/vista", "bin/vista-notice"],
    "minimum-stability": "stable",
    "scripts": {
        "post-install-cmd": "@php bin/vista-notice",
        "post-update-cmd": "@php bin/vista-notice"
    }
}
